{
  "name": "galley-obsidian",
  "version": "0.1.0",
  "description": "AI-driven Markdown-to-HTML publishing studio for Obsidian.",
  "author": "Kinrochen",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/isjiamu/Galley.git"
  },
  "funding": {
    "type": "individual",
    "url": "https://ifdian.net/a/kinrochen"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run embed:hugerte && node esbuild.config.mjs --watch",
    "build": "npm run embed:hugerte && tsc --noEmit && node esbuild.config.mjs production && node tools/generate-third-party-notices.mjs",
    "embed:hugerte": "node tools/embed-hugerte-assets.mjs",
    "embed:gzh-skill": "node tools/embed-gzh-skill.mjs",
    "test": "vitest run",
    "test:acceptance": "vitest run tests/acceptance",
    "test:watch": "vitest",
    "test:typecheck": "tsc -p tsconfig.test.json --noEmit",
    "benchmark:long": "node tools/benchmark-long.mjs",
    "audit:licenses": "node tools/audit-licenses.mjs",
    "audit:package": "node tools/audit-package.mjs",
    "audit:secrets": "node tools/audit-secrets.mjs",
    "audit:mobile": "node tools/audit-mobile-boundary.mjs",
    "audit:static": "npm run audit:secrets && npm run audit:mobile",
    "release": "npm run build && npm run audit:licenses && npm run audit:package && npm run audit:mobile && node tools/build-release.mjs && npm run audit:secrets"
  },
  "dependencies": {
    "@codemirror/commands": "6.10.4",
    "@codemirror/lang-html": "6.4.11",
    "@codemirror/language": "6.12.4",
    "@codemirror/view": "6.38.6",
    "@lezer/highlight": "1.2.3",
    "codemirror": "6.0.2",
    "dompurify": "3.4.12",
    "fflate": "0.8.3",
    "hugerte": "1.0.12",
    "mdast-util-from-markdown": "2.0.3",
    "mdast-util-gfm": "3.1.0",
    "micromark-extension-gfm": "3.0.0",
    "prettier": "3.9.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.10.0",
    "esbuild": "0.25.12",
    "jsdom": "26.1.0",
    "obsidian": "1.11.4",
    "typescript": "5.9.3",
    "vitest": "3.2.7"
  }
}
