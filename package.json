    "micromark-extension-gfm": "3.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.10.0",
    "esbuild": "0.25.12",
    "jsdom": "26.1.0",
    "obsidian": "1.11.4",
    "typescript": "5.9.3",
    "vitest": "3.2.7"
